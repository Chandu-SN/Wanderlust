<% layout("/layouts/boilerplate")%>

<div class="row mt-3">
    <div class="col-6 offset-3">
        <form action="/signup" method="POST"  novalidate class="needs-validation">
            <h3 >Signup for Wanderlust</h3>
            <div class=" mt-3 mb-3">
                <label for="username" class="form-label"> Username</label>
                <input name="username" placeholder="enter name" type="text" class="form-control" id="username" required />
                <div class="invalid-feedback">name should be valid</div>
              </div>
              <div class="mb-3">
                <label for="email" class="form-label"> Email</label>
                <input name="email" placeholder="enter email" class="form-control" id="email" required></input>
              </div>
              <div class="mb-3">
                <label for="password" class="form-label"> Password</label>
                <input name="password" placeholder="enter password" type="password" class="form-control" id="password" required></input>
              </div>
              <button class="btn btn-primary">Signup</button>
        </form>

    </div>
</div>